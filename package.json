{
  "name": "solid-dumb-kit",
  "version": "0.0.1",
  "description": "SolidJS UI components: SelectionArea, ResizableGrid and more",
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "solid-js": ">=1.8.0"
  },
  "dependencies": {
    "@solid-primitives/storage": "^4.3.4",
    "@viselect/vanilla": "^3.9.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^6.0.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/russelgal/solid-dumb-kit"
  },
  "keywords": [
    "solidjs",
    "solid",
    "ui",
    "components",
    "selection-area",
    "resizable-grid"
